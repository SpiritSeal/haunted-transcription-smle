.venv*
__pycache__/
*.pyc
_prev-*.png
Haunted_preview-*.png
assets/*.sf2
assets/*.sf3
.cache/

# Per-run audio renders (WAVs are heavy) — keep MIDI/PDF/XML committed
runs/*/audio/

# Raw htdemucs output (24 MB/stem) — source of truth is stems/
separated/

# Demucs-v3 stems kept around for A/B (8 MB × 6 = 48 MB). Restore with:
#   git show 52e38cd^:"stems/..." > stems_v3_demucs/...
stems_v3_demucs/

# Demucs-v3 basic-pitch regeneration output (fresh transcriptions; re-runnable
# via STEMS_DIR=stems_v3_demucs MIDI_DIR=midi_v3_demucs python transcribe_stems.py)
midi_v3_demucs/

# Local agent/editor state
.claude/

# MT3 vendored sources (cloned, editable-installed into .venv-mt3)
mt3_repo/
t5x_repo/

# MT3 checkpoints (~165 MB each; re-downloadable via transcribe_mt3.py)
assets/mt3_checkpoints/

# RVC vendored sources (cloned; installed into .venv-rvc)
rvc_repo/

# RVC training data + logs (re-producible from stems/ + scripts)
rvc_training/

